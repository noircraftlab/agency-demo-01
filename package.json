{
  "name": "agency-demo-01",
  "version": "0.1.0",
  "private": true,
  "description": "White-label proof-of-work: pixel-perfect WordPress build of the Whitepace SaaS Landing V2 Figma (Noircraft Lab).",
  "scripts": {
    "dev": "sass --watch src/scss/main.scss dist/css/main.css --style=expanded --source-map",
    "build": "sass src/scss/main.scss dist/css/main.css --style=expanded --source-map",
    "build:prod": "sass src/scss/main.scss dist/css/main.min.css --style=compressed --no-source-map"
  },
  "devDependencies": {
    "sass": "^1.77.8"
  }
}
